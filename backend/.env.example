# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
PORT=8080

# Database (PostgreSQL) — Neon: use key-value format on Render (avoids ?sslmode=require parsing issues)
ConnectionStrings__DefaultConnection=Host=your-host.neon.tech;Port=5432;Database=neondb;Username=neondb_owner;Password=your-password;SSL Mode=Require
# Or Neon URI (works locally; on Render prefer key-value format above):
# ConnectionStrings__DefaultConnection=postgresql://user:pass@host.neon.tech/neondb?sslmode=require

# JWT
Jwt__Secret=your-long-random-jwt-secret-at-least-32-characters
Jwt__Issuer=CouncillorsDesk
Jwt__Audience=CouncillorsDesk
Jwt__ExpirationMinutes=480

# Super Admin bootstrap (required on first run to create novielungu@gmail.com)
SUPER_ADMIN_PASSWORD=your_super_admin_password

# Google OAuth — set via environment variables (never commit real values)
# Required for Google Sign-In: ClientId (backend validates ID tokens from the frontend)
# Optional: ClientSecret (only needed for server-side Google OAuth middleware)
Google__ClientId=your-google-client-id.apps.googleusercontent.com
Google__ClientSecret=your-google-client-secret

# SMTP email
Smtp__Host=smtp.example.com
Smtp__Port=587
Smtp__Username=
Smtp__Password=
Smtp__FromEmail=noreply@area18.mw
Smtp__FromName=Area 18 Councillor's Desk
Smtp__UseSsl=true
Smtp__Enabled=true

# Twilio SMS (optional)
Twilio__AccountSid=
Twilio__AuthToken=
Twilio__FromPhoneNumber=

# Cloudinary image hosting (optional — falls back to local storage)
Cloudinary__CloudName=
Cloudinary__ApiKey=
Cloudinary__ApiSecret=

# Local file storage (used when Cloudinary is not configured)
LocalStorage__BasePath=uploads
LocalStorage__BaseUrl=/uploads

# Frontend URL for CORS and password-reset links
App__FrontendUrl=https://your-app.vercel.app
