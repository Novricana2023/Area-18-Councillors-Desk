# =============================================================================
# Area 18 Councillor's Desk — environment variables (PLACEHOLDERS ONLY)
# =============================================================================
# Copy sections to:
#   backend/.env          (API — gitignored)
#   frontend/.env.local   (Next.js — gitignored)
#
# ASP.NET Core uses double underscores: Section__Key
# =============================================================================

# --- Backend (API) ---
ASPNETCORE_ENVIRONMENT=Development
PORT=8080

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=councillors_desk_dev;Username=postgres;Password=your_local_postgres_password

Jwt__Secret=your-long-random-jwt-secret-at-least-32-characters
Jwt__Issuer=CouncillorsDesk
Jwt__Audience=CouncillorsDesk
Jwt__ExpirationMinutes=480

Google__ClientId=your_google_client_id.apps.googleusercontent.com
Google__ClientSecret=your_google_client_secret

SUPER_ADMIN_PASSWORD=your_super_admin_password

Smtp__Host=smtp.example.com
Smtp__Port=587
Smtp__Username=your_smtp_username
Smtp__Password=your_smtp_password
Smtp__FromEmail=noreply@area18.mw
Smtp__FromName=Area 18 Councillor's Desk
Smtp__UseSsl=true
Smtp__Enabled=false

Twilio__AccountSid=your_twilio_account_sid
Twilio__AuthToken=your_twilio_auth_token
Twilio__FromPhoneNumber=+265000000000

Cloudinary__CloudName=your_cloudinary_cloud_name
Cloudinary__ApiKey=your_cloudinary_api_key
Cloudinary__ApiSecret=your_cloudinary_api_secret

App__FrontendUrl=http://localhost:3000

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Docker PostgreSQL (local) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_local_postgres_password
POSTGRES_DB=councillors_desk
